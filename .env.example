# InfraNode API - Beispiel-Umgebungsvariablen
# Kopieren nach .env und Werte einsetzen. .env wird NICHT committet.
# Alle von der App gelesenen Variablen tragen den Prefix INFRANODE_
# (Settings.env_prefix). KEINE echten Secrets in diese Datei eintragen.

# --- Infrastruktur ---
INFRANODE_LOG_LEVEL=INFO
INFRANODE_REDIS_URL=redis://redis:6379/0
# CORS-Whitelist (JSON-Liste), niemals "*"
INFRANODE_CORS_ORIGINS=["http://localhost:3000"]

# --- Phase 11: Rate-Limiting + API-Keys (API-06/API-07) ---
# Rate-Limit-Tiers im limits/slowapi-Format "<zahl>/<einheit>". anon = anonymes
# IP-Budget, keyed = Budget mit gueltigem X-API-Key (hebt das Limit), mint =
# striktes Budget am Key-Mint-Endpunkt gegen Key-Flooding.
INFRANODE_LIMIT_ANON=300/minute
INFRANODE_LIMIT_KEYED=600/minute
INFRANODE_LIMIT_MINT=3/hour
# Striktes Budget am Admin-Login gegen Brute-Force (Audit HIGH-1).
INFRANODE_LIMIT_ADMIN_LOGIN=5/minute
# Sync-Redis-URI fuer slowapis eigene limits-Storage. Leer lassen = Fallback auf
# INFRANODE_REDIS_URL (selber Server, getrennte sync-Verbindung; slowapi teilt
# den async-Pool nicht). Beispiel: redis://redis:6379/0
INFRANODE_LIMIT_STORAGE_URI=
# Optionaler Pepper fuer den API-Key-Hash. Leer lassen = reiner sha256 ueber den
# Token. Gesetzt = Pepper wird vor dem Hash angehaengt. KEIN echtes Secret hier.
INFRANODE_APIKEY_PEPPER=

# --- Phase 13: Admin-Dashboard (OPS-01/OPS-02) ---
# Passwort fuer das Cookie-geschuetzte /admin-Dashboard. Leer lassen = Login
# unmoeglich (fail-closed, kein Zugang). KEIN echtes Secret in diese Datei.
INFRANODE_ADMIN_PASSWORD=
# Signier-Secret fuer das Session-Cookie (itsdangerous). Mindestens 32 Byte
# Zufall verwenden (z.B. `python -c "import secrets; print(secrets.token_hex(32))"`).
# Leer lassen = keine Session signierbar (fail-closed).
INFRANODE_ADMIN_SESSION_SECRET=
# Maximale Anzahl der im Redis-Ringpuffer gehaltenen Request-Logs (aelteste werden
# verworfen). Default 200.
INFRANODE_ADMIN_LOG_MAX=200
# Secure-Flag des Session-Cookies. true = Cookie nur ueber HTTPS (Produktion hinter
# Caddy/Cloudflare). Nur lokal/in Tests ohne TLS auf false setzen.
INFRANODE_ADMIN_COOKIE_HTTPS_ONLY=true

# --- Quellen-Toggles (true/false): jede Quelle einzeln aktivierbar (FND-02) ---
INFRANODE_ENABLE_WIKIDATA=true
INFRANODE_ENABLE_DWD=true
INFRANODE_ENABLE_OVERPASS=true
# Overpass-Endpunkt. Default = oeffentliche Instanz (nur fuer leichte Nutzung). Die
# oeffentliche Instanz untersagt Drittnutzer-Backends im Dauerbetrieb (Fair-Use);
# fuer Produktion eigene Instanz (Planet-Dump) oder Geofabrik eintragen.
INFRANODE_OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
INFRANODE_ENABLE_AUTOBAHN=true
INFRANODE_ENABLE_HVV=false
INFRANODE_ENABLE_DELFI=false
# Phase 7: Tier-A-Quellen (E-Mobilitaet und erweiterte Umweltdaten),
# alle keylos und bundesweit, daher Default true. enable_lhp = Hochwasser (LHP).
# BNETZA: Toggle steuert nur die /charging-Route (Snapshot-Read); die Daten
# stammen aus einem offline aktualisierten CSV-Datensatz, nicht mehr live.
INFRANODE_ENABLE_BNETZA=true
INFRANODE_ENABLE_UBA=true
INFRANODE_ENABLE_PEGELONLINE=true
INFRANODE_ENABLE_LHP=true
INFRANODE_ENABLE_DWD_POLLEN=true
# Phase 8: account-gated Quellen Default false (Credentials erforderlich):
# GENESIS = Demografie + Krankenhaus (regionalstatistik.de), ZENSUS = Zensus-Host,
# DIVI = klinikscharfe Intensivbetten-Live (Tier C, optional). Keylose Bulk-/Seed-
# Quellen Default true (MaStR-Energie, BKG-Geo, Bundeswahl, Feiertage/Ferien).
INFRANODE_ENABLE_GENESIS=false
INFRANODE_ENABLE_ZENSUS=false
INFRANODE_ENABLE_DIVI=false
INFRANODE_ENABLE_MASTR=true
INFRANODE_ENABLE_BKG=true
INFRANODE_ENABLE_BUNDESWAHL=true
INFRANODE_ENABLE_FEIERTAGE=true
# Phase 9: keylose Stadt-Verkehrs-Quellen (Baustellen/Sperrungen) je Stadt +
# Autobahn-Webcam-Sub-Service. Alle keylos, daher Default true (analog
# INFRANODE_ENABLE_AUTOBAHN). Keine neuen Secrets.
INFRANODE_ENABLE_BERLIN_VIZ=true
INFRANODE_ENABLE_HAMBURG_BAUSTELLEN=true
INFRANODE_ENABLE_KOELN_VERKEHR=true
INFRANODE_ENABLE_MUENCHEN_BAUSTELLEN=true
INFRANODE_ENABLE_MOBIDATA_BW=true
INFRANODE_ENABLE_AUTOBAHN_WEBCAM=true
# Phase 10: Stadt-Events/Veranstaltungen. destination.one ist KEYLOS: die
# Experience "open-data" ist frei zugaenglich (Support-Bestaetigung 2026-06-10),
# daher Default true. koeln_events ist ebenfalls keylos, Default true.
INFRANODE_ENABLE_DESTINATION_ONE=true
INFRANODE_ENABLE_KOELN_EVENTS=true

# --- API-Keys / Credentials (leer lassen = Quelle nicht nutzbar, Graceful Degradation) ---
# HVV / Geofox (Hamburg): Key per Vereinbarung
INFRANODE_HVV_API_KEY=
# GENESIS / Regionalstatistik (account-gated POST-API). Konto unter
# regionalstatistik.de -> Registrierung/Mein Konto. Hinweis: das Settings-Feld
# heisst genesis_username, mappt also auf INFRANODE_GENESIS_USERNAME (NICHT
# INFRANODE_GENESIS_USER). Eine evtl. vorhandene SOURCE_GENESIS_ENABLED-Variable
# ist Legacy und wird NICHT gelesen; nur INFRANODE_ENABLE_GENESIS greift.
INFRANODE_GENESIS_USERNAME=
INFRANODE_GENESIS_PASSWORD=
# Regionalstatistik.de GENESIS-Webservice (DATA-37: Realsteuer-Hebesaetze 71231 +
# Gewerbean-/-abmeldungen 52311). Header-Auth username/password, NUR im Bulk-Ingest
# (python -m infranode.ingest.regionalstatistik), NIE im Request-Pfad. Ohne diese
# Credentials liefern /tax-rates + /business-registrations 200 disabled.
INFRANODE_REGIO_USER=
INFRANODE_REGIO_PASS=
# Zensus (ergebnisse.zensus2022.de): evtl. getrennter Account (RESEARCH A4).
INFRANODE_ZENSUS_USER=
INFRANODE_ZENSUS_PASSWORD=
# RMV HAPI (Rhein-Main, Frankfurt): accessId-Auth, https://www.rmv.de/hapi/.
# Open Data, aber KEIN GTFS (nur Haltestellen-Datei opendata.rmv.de). Tier/Lizenz
# VOR produktiver Nutzung pruefen (vermutlich Tier C live-only, wie HVV/geofox).
# API-Migration auf v2.52.0 zum 2026-09-22 (Testumgebung https://www.rmv.de/hapi/latest/).
INFRANODE_RMV_ACCESS_ID=
# destination.one / eT4.META (Stadt-Events, Phase 10): KEIN Key noetig, die
# Experience "open-data" ist frei zugaenglich (verifiziert 2026-06-10).

# --- Lokales Datenverzeichnis ---
# Wurzelpfad des lokalen Datenverzeichnisses (Feld-/Env-Name aus
# Kompatibilitaetsgruenden unveraendert).
# In Docker als Volume gemountet (deploy/docker-compose.yml).
# INFRANODE_ARCHIVE_DIR=data/archive

# --- Operative Hinweise fuer spaetere Phasen (noch nicht von Settings gelesen) ---
# Pflicht-kontaktierbarer User-Agent fuer Wikidata/Overpass/DWD (Fair-Use), ab Phase 3/4
# INFRANODE_HTTP_USER_AGENT=InfraNode/0.1 (+https://github.com/street1983nk/infranode-api; contact@example.com)
# DELFI / opendata-oepnv.de: kein Laufzeit-Key, GTFS-ZIP-Pfad/URL, ab Phase 6
# INFRANODE_DELFI_GTFS_PATH=./data/delfi/gtfs.zip
# Phase 8: lokale Bulk-Datei-Pfade fuer die Offline-Aufbereitung, nie im
# Request-Pfad. None/unset = Aufbereitung nicht lauffaehig.
# INFRANODE_MASTR_ZIP_PATH=./data/mastr/Gesamtdatenexport.zip
# INFRANODE_BKG_PATH=./data/bkg/vg250.geojson
# INFRANODE_BUNDESWAHL_CSV_PATH=./data/bundeswahl/kerg2.csv
# INFRANODE_DIVI_CSV_PATH=./data/divi/divi_landkreise.csv

# --- Mobilithek M2M (DATEX-II V2 Pull, mutual TLS, Port 8443) ---
# Maschinenkonto-Zertifikat (.p12) der Org, ein Cert fuer ALLE abonnierten Mobilithek-Angebote.
# Beziehbar via Mobilithek-Portal -> Meine Organisation -> Maschinenkonten -> "Zertifikat beantragen".
# Datei gitignored unter secrets/ ablegen (NICHT committen), Passwort nur in .env.
INFRANODE_MOBILITHEK_CERT_PATH=secrets/mobilithek-<name>.p12
INFRANODE_MOBILITHEK_CERT_PASSWORD=

# --- Phase 14: Hetzner-Deployment + Cloudflare (DEP-01/DEP-02) ---
# Cloudflare-API-Token fuer Caddys DNS-01-Challenge (Auto-HTTPS in Prod). Scope
# minimal halten: Zone.Zone:Read + Zone.DNS:Edit, NUR fuer die Zone infranode.dev.
# Dieses Token wird AUSSCHLIESSLICH von Caddy via {env....}-Referenz im Caddyfile
# gelesen, NICHT von den Pydantic-Settings der App. Leer lassen im Repo, niemals
# ein echtes Token committen (gitleaks-CI faengt versehentliche Secrets, FND-07).
INFRANODE_CF_DNS_TOKEN=
# Oeffentliche API-Domain (Caddy-Site-Block + Doku-/CORS-Bezug).
INFRANODE_PUBLIC_DOMAIN=infranode.dev

# --- Phase 16: Monitoring/Alarmierung/Selbstheilung (OPS-06/07/08) ---
# ntfy-Push-Kanal fuer Alarme. INFRANODE_NTFY_URL = Basis-URL des ntfy-Servers
# (self-hosted oder https://ntfy.sh). INFRANODE_NTFY_TOPIC ist faktisch ein
# Passwort (nur a-z/0-9/_/- verwenden, nicht erraten lassen). INFRANODE_NTFY_TOKEN
# = Bearer-Zugriffstoken. Alle drei nur via .env, nie ins Repo (KEIN echtes Secret).
INFRANODE_NTFY_URL=
INFRANODE_NTFY_TOPIC=
INFRANODE_NTFY_TOKEN=
# SMTP-E-Mail-Backup-Kanal. INFRANODE_SMTP_SSL=false = STARTTLS auf Port 587
# (Default), true = SMTP_SSL auf Port 465. INFRANODE_SMTP_PASSWORD nur via .env,
# nie ins Repo (KEIN echtes Secret). Leer lassen = E-Mail-Backup deaktiviert.
INFRANODE_SMTP_HOST=
INFRANODE_SMTP_PORT=587
INFRANODE_SMTP_USER=
INFRANODE_SMTP_PASSWORD=
INFRANODE_SMTP_FROM=
INFRANODE_SMTP_TO=
INFRANODE_SMTP_SSL=false
# Dead-Man-Ping je Timer-Job (Kuma-Push- bzw. Healthchecks.io-Ping-URL). Wird per
# systemd-Drop-in je Job ueberschrieben. Leer lassen = kein Ping. URL traegt ein
# Token/UUID und ist wie ein Secret zu behandeln (nur via .env, nie ins Repo).
INFRANODE_DEADMAN_URL=
# Externer Box-Liveness-Ping (Finding 8): der Watchdog pingt diese URL am Ende
# jedes erfolgreichen Laufs. Die URL traegt eine UUID und ist wie ein Secret zu
# behandeln (nur via .env, nie ins Repo, analog DEADMAN_URL; HTTPS-Ziel).
INFRANODE_HEALTHCHECKS_URL=
# Self-Heal-Reprobe (A, 2026-06-14): opt-in-Liste BEWUSST per enable_*-Toggle
# deaktivierter Quellen, deren Upstream der Watchdog periodisch direkt anprobt.
# Lebt der Upstream wieder, kommt genau ein "X reaktivierbar"-ntfy (Reaktivierung
# bleibt manuell). Format komma-separiert: source=ProbeURL,source2=ProbeURL2.
# Beispiel: hamburg_verkehrslage=https://api.hamburg.de/datasets/v1/verkehrslage/collections/verkehrslage/items?f=json&limit=1
# Leer = aus. (Enabled gelassene Quellen heilen ohnehin ueber den persistenten
# Breaker mit Per-Source-Cooldown, kein Eintrag noetig.)
INFRANODE_SELFHEAL_PROBES=

# --- Prod-PFLICHT-Hinweis (vor dem Public-Launch zwingend setzen) ---
# Die folgenden bereits oben definierten Variablen MUESSEN in Produktion echte
# Werte tragen, sonst ist der Betrieb unsicher oder fail-closed (kein Zugang):
#   INFRANODE_ADMIN_PASSWORD         - ohne Wert ist /admin-Login unmoeglich
#   INFRANODE_ADMIN_SESSION_SECRET   - ohne Wert keine Session signierbar
#       beide mit `python -c "import secrets; print(secrets.token_hex(32))"` erzeugen
#   INFRANODE_ADMIN_COOKIE_HTTPS_ONLY=true  - in Prod Pflicht (Cookie nur ueber HTTPS)
#   INFRANODE_CORS_ORIGINS           - in Prod auf die echte Docs-/infranode.dev-Domain
#       setzen (z.B. ["https://infranode.dev"]), NIEMALS "*".
