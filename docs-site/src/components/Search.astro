---
// Eigene Such-UI (D-01, kein vorgefertigtes Pagefind-Default-UI). Lädt zur
// Laufzeit /pagefind/pagefind.js dynamisch (existiert erst nach postbuild),
// ruft pagefind.search(query) und rendert Treffer in eigenem Markup. Das
// Sucheingabe-Icon ist inline-SVG (CLAUDE.md: Icons als SVG, keine Emojis).
// Ergebnis-Titel/Excerpts kommen direkt von Pagefind als sub_result.excerpt
// (bereits sanitisiertes HTML mit <mark>); wir setzen Titel via textContent
// und Excerpt via die Pagefind-eigene markierte Ausgabe.
interface Props {
  // Sprache der Seite (de Standard). Steuert Placeholder/aria-label der Suche.
  lang?: "de" | "en";
}
const { lang = "de" } = Astro.props;
const isEn = lang === "en";
const searchLabel = isEn ? "Search docs" : "Doku durchsuchen";
// Lokalisierte Leerzustands-Texte (D-09): werden zur Laufzeit aus Daten-
// Attributen gelesen, damit das Skript sprachunabhängig bleibt.
const msgEmpty = isEn ? "No results for" : "Keine Treffer für";
const msgLoading = isEn ? "Search is still loading…" : "Suche lädt noch …";
---

<div
  class="search"
  data-search
  data-msg-empty={msgEmpty}
  data-msg-loading={msgLoading}
>
  <div class="search__field">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      type="search"
      class="search__input"
      placeholder={searchLabel}
      aria-label={searchLabel}
      data-search-input
    />
    <kbd class="search__kbd" aria-hidden="true">/</kbd>
  </div>
  <div class="search__results" data-search-results role="listbox"></div>
</div>

<script>
  // Pagefind-Typen sind zur Build-Zeit nicht vorhanden; lose typisieren.
  type PagefindSubResult = { title: string; url: string; excerpt: string };
  type PagefindResult = { data: () => Promise<{ url: string; meta: { title?: string }; excerpt: string; sub_results?: PagefindSubResult[] }> };
  type Pagefind = { search: (q: string) => Promise<{ results: PagefindResult[] }> };

  const root = document.querySelector<HTMLElement>("[data-search]");
  if (root) {
    const input = root.querySelector<HTMLInputElement>("[data-search-input]")!;
    const out = root.querySelector<HTMLElement>("[data-search-results]")!;
    const msgEmpty = root.dataset.msgEmpty || "Keine Treffer für";
    const msgLoading = root.dataset.msgLoading || "Suche lädt noch …";
    let pagefind: Pagefind | null = null;
    let loading = false;
    let timer: number | undefined;

    async function ensurePagefind(): Promise<Pagefind | null> {
      if (pagefind || loading) return pagefind;
      loading = true;
      try {
        // /pagefind/pagefind.js existiert erst nach dem postbuild im dist und
        // ist zur Build-Zeit nicht auflösbar. Der Pfad wird zur Laufzeit
        // zusammengesetzt, damit Rollup ihn nicht statisch zu resolven
        // versucht (sonst bricht der Build mit "failed to resolve import").
        const path = ["", "pagefind", "pagefind.js"].join("/");
        const mod = await import(/* @vite-ignore */ path);
        pagefind = mod as unknown as Pagefind;
      } catch {
        pagefind = null;
      }
      loading = false;
      return pagefind;
    }

    function clear(): void {
      out.replaceChildren();
    }

    // Leerzustands-/Statusmeldung (D-09): reiner Text via textContent, damit der
    // Ergebnis-Container nicht leer ist (:empty-Regel greift dann nicht mehr).
    function showMsg(text: string): void {
      const p = document.createElement("p");
      p.className = "search__msg";
      p.textContent = text;
      out.replaceChildren(p);
    }

    async function run(query: string): Promise<void> {
      const q = query.trim();
      if (q.length < 2) {
        clear();
        return;
      }
      const pf = await ensurePagefind();
      if (!pf) {
        showMsg(msgLoading);
        return;
      }
      const search = await pf.search(q);
      clear();
      const top = search.results.slice(0, 8);
      if (top.length === 0) {
        showMsg(`${msgEmpty} „${q}“`);
        return;
      }
      for (const result of top) {
        const data = await result.data();
        const link = document.createElement("a");
        link.className = "search__result";
        link.href = data.url;
        link.setAttribute("role", "option");

        const title = document.createElement("span");
        title.className = "search__result-title";
        // Titel als reiner Text (textContent, kein innerHTML, T-12-XSS-Geist).
        title.textContent = data.meta.title || data.url;

        const excerpt = document.createElement("span");
        excerpt.className = "search__result-excerpt";
        // Pagefind liefert excerpt als markiertes (sanitisiertes) Snippet mit
        // <mark>; das ist Pagefind-eigene, nicht nutzergesteuerte Ausgabe.
        excerpt.innerHTML = data.excerpt;

        link.append(title, excerpt);
        out.append(link);
      }
    }

    input.addEventListener("input", () => {
      window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        void run(input.value);
      }, 150);
    });

    // Tastatur-Shortcut (Flexibilität für Power-User): "/" oder Cmd/Strg+K
    // fokussiert die Suche, greift nicht während man in einem Feld tippt.
    // Escape leert die Suche und verlässt das Feld.
    document.addEventListener("keydown", (e) => {
      const el = document.activeElement;
      const typing =
        el instanceof HTMLElement &&
        (el.tagName === "INPUT" || el.tagName === "TEXTAREA" || el.isContentEditable);
      if ((e.key === "/" && !typing) || ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k")) {
        e.preventDefault();
        input.focus();
        input.select();
      } else if (e.key === "Escape" && el === input) {
        input.value = "";
        clear();
        input.blur();
      }
    });
  }
</script>
