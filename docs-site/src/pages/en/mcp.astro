---
// English MCP page. Mirrors the German /mcp page with idiomatic copy.
import Docs from "../../layouts/Docs.astro";
import CodeTabs from "../../components/CodeTabs.astro";
import JsonLd from "../../components/JsonLd.astro";

// The server is publicly hosted (remote, Streamable HTTP) at
// https://mcp.infranode.dev/mcp. Tab 1: Claude Code (remote, one command),
// Tab 2: URL connector config, Tab 3: local self-host (stdio, needs repo access).
const MCP_URL = "https://mcp.infranode.dev/mcp";

const claudeCodeRemote = `claude mcp add --transport http infranode ${MCP_URL}`;

const connectorConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "url": "${MCP_URL}"`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

const claudeCodeLocal = `claude mcp add infranode -- uv run --group mcp python -m infranode.mcp`;

// Fallback for clients that only support local stdio servers (no remote URL):
// the standard mcp-remote bridge pipes stdio to the hosted endpoint via npx.
const mcpRemoteConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "command": "npx",`,
  `      "args": ["-y", "mcp-remote", "${MCP_URL}"]`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

const toolGroups = [
  {
    title: "Core and geo",
    tools: [
      ["get_city", "City master data"],
      ["geo", "Geo data"],
      ["demographics", "Demographics"],
    ],
  },
  {
    title: "Environment and weather",
    tools: [
      ["air_quality", "Air quality"],
      ["air_quality_live", "Air quality, live readings"],
      ["weather", "Weather"],
      ["weather_warnings", "Official DWD weather warnings (severe weather, level)"],
      ["pollen_uv", "Pollen and UV index"],
    ],
  },
  {
    title: "Mobility and traffic",
    tools: [
      ["traffic", "Traffic situation"],
      ["transit", "Public transit stops"],
      ["transit_departures", "Live transit departures with delays (stop_id param)"],
      ["charging", "Charging stations"],
      ["road_events", "Road and construction notices"],
      ["vehicle_registrations", "Car stock and electric vehicle share (KBA)"],
      ["accidents", "Road traffic accidents per county (accident atlas)"],
      ["fuel_prices", "Fuel prices per city, aggregated (Tankerkönig)"],
      ["sharing", "Bike and scooter sharing per city, aggregated (GBFS/Nextbike)"],
      ["station_departures", "Live departures at the long-distance main station with delays (DB Timetables)"],
      ["station_arrivals", "Live arrivals at the long-distance main station with delays (DB Timetables)"],
    ],
  },
  {
    title: "Water and situation",
    tools: [
      ["water_level", "Water levels"],
      ["flood", "Flood situation"],
    ],
  },
  {
    title: "Health and energy",
    tools: [
      ["health", "Health data"],
      ["icu_live", "ICU beds, live"],
      ["energy", "Energy installations (market master data register)"],
      ["power_load", "Electricity consumption / grid load per control zone (SMARD)"],
      ["power_price", "Day-ahead wholesale power price (SMARD)"],
    ],
  },
  {
    title: "Economy and statistics",
    tools: [
      ["unemployment", "Unemployment count and rate per county"],
      ["tourism", "Guest overnight stays and arrivals (tourism)"],
      ["construction", "Building permits (residential buildings and dwellings)"],
      ["indicators", "Socioeconomic indicators per county (INKAR/BBSR, ~70 metrics)"],
    ],
  },
  {
    title: "City life and politics",
    tools: [
      ["pois", "Points of interest (required type parameter, e.g. hospital)"],
      ["events", "Events"],
      ["webcams", "Webcams"],
      ["election", "Election results"],
      ["holidays", "Public holidays"],
    ],
  },
  {
    title: "Overview and meta",
    tools: [
      ["list_cities", "List of all covered cities (slugs, coverage)"],
      ["sources", "All data sources with licence and availability"],
    ],
  },
];

// FAQ for the FAQPage JSON-LD (GEO: directly quotable by AI answer engines and
// Google). Plain text, serialised safely in JsonLd.astro.
const faq = [
  {
    q: "How do I connect the InfraNode MCP server to Claude or ChatGPT?",
    a: "Add the hosted endpoint https://mcp.infranode.dev/mcp as a connector. In Claude Code: claude mcp add --transport http infranode https://mcp.infranode.dev/mcp. No install needed.",
  },
  {
    q: "Does the InfraNode MCP server need an API key?",
    a: "No. Access is read-only, key-free and free of charge; only a fair per-IP limit applies.",
  },
  {
    q: "What data does the InfraNode MCP server provide?",
    a: "37 tools for open data of 84 major German cities: master data, air quality, weather and weather warnings, public transit incl. live departures, traffic, water levels and flooding, health, energy and power market, car stock and electric share, unemployment, tourism, building permits, road accidents, fuel prices, bike and scooter sharing, POIs, events, elections and holidays, station departures and arrivals, plus a cities and a sources overview.",
  },
  {
    q: "My MCP client only supports local stdio servers. How do I connect InfraNode?",
    a: "Use the standard mcp-remote bridge: command npx with args -y mcp-remote https://mcp.infranode.dev/mcp. It pipes stdio to the hosted endpoint, with no repo and no key. There is no package via pip, uvx or npx infranode.",
  },
  {
    q: "Can I self-host the InfraNode MCP server?",
    a: "Yes, locally over stdio. That requires repository access; the source-code release is in preparation.",
  },
];
---

<Docs
  title="MCP server"
  description="Hosted InfraNode MCP server at mcp.infranode.dev: 37 tools for AI agents, remote over Streamable HTTP, no install, no API key. Connector for Claude and ChatGPT."
  current="mcp"
  lang="en"
  altLangPath="/mcp/"
>
  <JsonLd
    slot="jsonld"
    type="SoftwareApplication"
    name="InfraNode MCP server"
    description="Hosted MCP server with 37 tools for open city data of 84 major German cities, key-free and free of charge."
  />
  <JsonLd slot="jsonld" type="FAQPage" faq={faq} />

  <h1>MCP server</h1>
  <p>
    The InfraNode MCP server is a free, hosted Model Context Protocol server that
    gives AI agents access to open data for 84 major German cities through 37
    tools, with no API key. It exposes the city data as tools an agent calls
    directly, so you do not write HTTP calls by hand.
  </p>

  <div class="tldr">
    <p class="tldr__title">Connect now</p>
    <p>
      The server is publicly hosted at <code>https://mcp.infranode.dev/mcp</code>
      (Streamable HTTP). No install, no API key: add it as a connector with that
      URL in Claude, ChatGPT or any other MCP client and you are done.
    </p>
  </div>

  <h2>What is MCP</h2>
  <p>
    The Model Context Protocol (MCP) is an open standard through which AI agents
    plug in external tools and data sources. An MCP server registers its tools
    with the client, the agent calls them with typed arguments when needed and
    receives structured JSON back. For you as a developer that means: instead of
    building an API integration, you connect a server once and your agent can use
    the data right away. The InfraNode server is reachable remotely over
    Streamable HTTP and needs no local process; alternatively it runs locally
    over stdio.
  </p>

  <h2>Connect (remote, recommended)</h2>
  <p>
    The fastest path: add the hosted endpoint
    <code>https://mcp.infranode.dev/mcp</code> as a connector. In Claude Code a
    single command does it (first tab). Clients with URL connector configuration
    (Claude Desktop, ChatGPT and others) use the JSON form in the second tab or
    enter the URL directly in their connector UI.
  </p>
  <CodeTabs
    curl={claudeCodeRemote}
    js={connectorConfig}
    py={claudeCodeLocal}
    id="codetabs-mcp-setup-en"
    labels={["Claude Code (remote)", "Connector by URL", "Local (stdio)"]}
    lang="en"
  />
  <p>
    Once added, the 37 InfraNode tools are available in the agent. Access is
    read-only and key-free.
  </p>

  <h2>Connect stdio-only clients (npx mcp-remote)</h2>
  <p>
    Some MCP clients only support local stdio servers, not a remote URL. For them
    the standard <code>mcp-remote</code> tool bridges the gap: it runs locally via
    <code>npx</code> and pipes stdio to the hosted endpoint. No repo, no key, no
    InfraNode install required.
  </p>
  <pre class="codetabs__pre"><code>{mcpRemoteConfig}</code></pre>
  <p>
    If your client supports remote URL connectors (Claude, ChatGPT), the direct
    route above is simpler. <code>mcp-remote</code> is only the fallback for
    purely local stdio clients. Note: there is deliberately no package via
    <code>pip</code>, <code>uvx</code> or <code>npx infranode</code>, the hosted
    endpoint is the intended path.
  </p>

  <h2>Run it locally (optional)</h2>
  <p>
    If you prefer to self-host, run the server locally over stdio (third tab).
    That requires repository access; the source-code release is in preparation.
    The <code>INFRANODE_MCP_API_BASE</code> environment variable sets the API base
    it talks to (default <code>https://infranode.dev/api/v1</code>).
  </p>

  <h2>What the server runs against</h2>
  <p>
    The MCP server is a thin wrapper around the InfraNode live API. Each tool
    calls the REST API and passes its normalised JSON through unchanged. There is
    no mapping logic in the server and no API key for read access.
  </p>

  <h2>Tool overview</h2>
  <p>
    The server provides 37 tools in total. Most expect a city slug (for example
    <code>berlin</code> or <code>hamburg</code>); <code>pois</code> also requires
    a <code>type</code> parameter (e.g. <code>hospital</code>,
    <code>school</code>, <code>pharmacy</code>), and
    <code>transit_departures</code> optionally takes a <code>stop_id</code>.
    <code>list_cities</code> and <code>sources</code> need no argument.
  </p>
  {
    toolGroups.map((group) => (
      <>
        <h3>{group.title}</h3>
        <table class="params">
          <thead>
            <tr>
              <th>Tool</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {group.tools.map(([name, desc]) => (
              <tr>
                <td>
                  <code>{name}</code>
                </td>
                <td>{desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    ))
  }

  <h2>Example call</h2>
  <p>
    An agent fetches the master data for Berlin. The result is the live API's
    normalised JSON, passed through unchanged.
  </p>
  <pre class="codetabs__pre"><code>get_city(slug="berlin")</code></pre>
</Docs>
