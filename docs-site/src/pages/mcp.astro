---
// MCP-Server-Seite (/mcp): erklaert kurz MCP fuer Devs, zeigt die Einrichtung
// in Claude Code und Claude Desktop (CodeTabs) und listet die 42 Tools nach
// Thema gruppiert. Quelle der Einrichtungs-Snippets ist docs/mcp-install.md.
import Docs from "../layouts/Docs.astro";
import CodeTabs from "../components/CodeTabs.astro";
import JsonLd from "../components/JsonLd.astro";
import { mcpTopics } from "../data/mcp-topics";

// Einrichtungs-Snippets. Der Server ist oeffentlich gehostet (Remote, Streamable
// HTTP) unter https://mcp.infranode.dev/mcp. Tab 1: Claude Code (Remote, ein
// Befehl), Tab 2: URL-Connector-Config (Claude Desktop/ChatGPT u.a.), Tab 3:
// lokale Selfhost-Variante (stdio, braucht Repo-Zugang).
const MCP_URL = "https://mcp.infranode.dev/mcp";

const claudeCodeRemote = `claude mcp add --transport http infranode ${MCP_URL}`;

const connectorConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "url": "${MCP_URL}"`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

const claudeCodeLocal = `claude mcp add infranode -- uv run --group mcp python -m infranode.mcp`;

// Fallback fuer Clients, die nur lokale stdio-Server koennen (keine Remote-URL):
// die Standard-Bridge mcp-remote leitet stdio per npx an den gehosteten Endpunkt.
const mcpRemoteConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "command": "npx",`,
  `      "args": ["-y", "mcp-remote", "${MCP_URL}"]`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

// Die 42 Tools, thematisch gruppiert (Quelle docs/mcp-install.md).
