// Befehl), Tab 2: URL-Connector-Config (Claude Desktop/ChatGPT u.a.), Tab 3:
// lokale Selfhost-Variante (stdio, braucht Repo-Zugang).
const MCP_URL = "https://mcp.infranode.dev/mcp";

const claudeCodeRemote = `claude mcp add --transport http infranode ${MCP_URL}`;

const connectorConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "url": "${MCP_URL}"`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

const claudeCodeLocal = `claude mcp add infranode -- uv run --group mcp python -m infranode.mcp`;

// Fallback fuer Clients, die nur lokale stdio-Server koennen (keine Remote-URL):
// die Standard-Bridge mcp-remote leitet stdio per npx an den gehosteten Endpunkt.
const mcpRemoteConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "command": "npx",`,
  `      "args": ["-y", "mcp-remote", "${MCP_URL}"]`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

