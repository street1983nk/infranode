const claudeCodeRemote = `claude mcp add --transport http infranode ${MCP_URL}`;

const connectorConfig = [
  `{`,
  `  "mcpServers": {`,
  `    "infranode": {`,
  `      "url": "${MCP_URL}"`,
  `    }`,
  `  }`,
  `}`,
].join("\n");

