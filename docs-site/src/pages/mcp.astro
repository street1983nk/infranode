// FAQ fuer FAQPage-JSON-LD (GEO: direkt von KI-Antwortmaschinen + Google
// zitierbar). Reiner Text, wird in JsonLd.astro sicher serialisiert.
const faq = [
  {
    q: "Wie verbinde ich den InfraNode-MCP-Server mit Claude oder ChatGPT?",
