      ["sharing", "Bike- und Scooter-Sharing je Stadt, aggregiert (GBFS/Nextbike)"],
      ["station_departures", "Live-Abfahrten am Fernverkehrs-Hbf mit Verspätung (DB Timetables)"],
      ["station_arrivals", "Live-Ankünfte am Fernverkehrs-Hbf mit Verspätung (DB Timetables)"],
    ],
  },
  {
    title: "Wasser und Lage",
    tools: [
      ["water_level", "Pegelstände"],
      ["flood", "Hochwasserlage"],
    ],
  },
  {
    title: "Gesundheit und Energie",
    tools: [
      ["health", "Gesundheitsdaten"],
      ["icu_live", "Intensivbetten, Live"],
      ["energy", "Energieanlagen (Marktstammdatenregister)"],
      ["power_load", "Stromverbrauch / Netzlast je Regelzone (SMARD)"],
